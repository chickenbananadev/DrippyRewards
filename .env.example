# Drippy Rewards — environment variables
# Copy this file to .env.local for local development. NEVER commit .env.local or .env.
# Production values are configured in Vercel Project Settings → Environment Variables.

# ── Redis (Upstash) ──────────────────────────────
# Used for leaderboards, sessions, burn ledger, linked wallets, etc.
KV_REST_API_URL=https://your-instance.upstash.io
KV_REST_API_TOKEN=...
# Older code path / fallback (same values):
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Solana RPC (Helius) ──────────────────────────
# Used for burn verification, holdings checks, etc.
HELIUS_API_KEY=...

# Webhook secret used by /api/burn-webhook to verify Helius callbacks.
HELIUS_WEBHOOK_SECRET=...

# ── Admin / session secrets ──────────────────────
# Single secret for:
#   - admin auth on /api/events, /api/leaderboard PUT/DELETE, etc.
#   - fallback HMAC for session cookies (if DRIPPY_SESSION_SECRET not set)
DRIPPY_EVENTS_SECRET=some-long-random-string-min-32-chars

# Dedicated HMAC secret for session cookies (optional; falls back to DRIPPY_EVENTS_SECRET)
DRIPPY_SESSION_SECRET=another-long-random-string-min-32-chars

# ── Vercel Blob (image uploads for events) ───────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ── Treasury wallet for skin purchases (Squads multi-sig) ──
# Receive address for SOL skin purchases. Will be set when buy flow ships.
DRIPPY_TREASURY_SOL_WALLET=
