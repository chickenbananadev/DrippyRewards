{
  "version": 2,
  "functions": {
    "api/wallet.js": {
      "maxDuration": 30
    },
    "api/backfill-burns.js": {
      "maxDuration": 60
    },
    "api/stats.js": {
      "maxDuration": 20
    },
    "api/*.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/game",
      "destination": "/game.html"
    },
    {
      "source": "/play",
      "destination": "/game.html"
    },
    {
      "source": "/security",
      "destination": "/security.html"
    },
    {
      "source": "/community",
      "destination": "/community.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=(), payment=(), usb=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://plugin.jup.ag https://*.jup.ag https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://*.jup.ag; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://*.upstash.io https://api.helius.xyz https://*.helius-rpc.com https://*.solana.com wss://*.solana.com https://*.jup.ag https://fonts.googleapis.com https://fonts.gstatic.com; frame-src https://dexscreener.com https://www.dextools.io https://*.jup.ag; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/game",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/play",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/community",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/(tails-end-sprites|tails-end-audio|app)\\.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate, max-age=0"
        }
      ]
    }
  ]
}